pipeline {
    agent { label 'backup-agent' }

    triggers {
        cron('0 2 * * *')  // Daily at 2 AM
    }

    environment {
        WORKSPACE_DIR = "${WORKSPACE}"
        DATABASES = 'ffm,payment-gate'
    }

    stages {
        stage('Create .env file') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'vault-config', usernameVariable: 'VAULT_ADDR', passwordVariable: 'VAULT_TOKEN')]) {
                    script {
                        sh '''#!/bin/bash
                            set -e

                            echo "📦 CREATE .ENV FILE FROM VAULT"

                            export VAULT_ADDR="${VAULT_ADDR}"
                            export VAULT_TOKEN="${VAULT_TOKEN}"

                            vault kv get -field=dev-env cubbyhole/backdatup > "${WORKSPACE}/.env"
                            ls -la "${WORKSPACE}/.env"
                        '''
                    }
                }
            }
        }

        stage('Backup All Databases') {
            steps {
                script {
                    def databases = env.DATABASES.split(',')

                    databases.each { dbName ->
                        echo "🐘 Backing up database: ${dbName}"

                        sh """#!/bin/bash
                            set -e

                            echo "🔧 Configuring for database: ${dbName}"

                            cp "${WORKSPACE}/.env" "${WORKSPACE}/.env.current"

                            if grep -q "^POSTGRES_DB=" "${WORKSPACE}/.env.current"; then
                                sed -i 's/^POSTGRES_DB=.*/POSTGRES_DB=${dbName}/' "${WORKSPACE}/.env.current"
                            else
                                echo "POSTGRES_DB=${dbName}" >> "${WORKSPACE}/.env.current"
                            fi

                            mv "${WORKSPACE}/.env.current" "${WORKSPACE}/.env"

                            echo "🚀 Starting PostgreSQL backup for ${dbName}"
                            cd "${WORKSPACE}"
                            bash prevention/psql-backup.sh

                            echo "✅ PostgreSQL backup completed for ${dbName}"
                        """
                    }
                }
            }
        }

        stage('Persist to RAID') {
            steps {
                script {
                    sh '''#!/bin/bash
                        set -e

                        echo "💾 Persisting backups to RAID storage"

                        cd "${WORKSPACE}"
                        bash storage/persist-dumps.sh

                        echo "✅ Backups persisted to RAID"
                    '''
                }
            }
        }

        stage('Cleanup Old Backups') {
            steps {
                script {
                    sh '''#!/bin/bash
                        set -e

                        echo "🧹 Cleaning up old backups from RAID"

                        cd "${WORKSPACE}"
                        bash storage/cleanup.sh

                        echo "✅ Old backups cleaned up"
                    '''
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ PostgreSQL backup pipeline completed successfully"
        }
        failure {
            echo "❌ PostgreSQL backup pipeline failed"
        }
    }
}
